# Скопируй в .env и заполни своими значениями. .env в git НЕ коммитится.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
YANDEX_EMAIL=
YANDEX_PASSWORD=
# Фильтр по отправителю: слать только письма от этого адреса. Пусто = от всех.
TARGET_EMAIL=
IMAP_HOST=imap.yandex.ru
POLL_INTERVAL=60
# Необязательно: прокси для Telegram, если api.telegram.org недоступен напрямую.
# Примеры: http://HOST:PORT  или  socks5://HOST:PORT
TELEGRAM_PROXY=
